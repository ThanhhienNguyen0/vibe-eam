generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MODELER
  VIEWER
}

enum BranchStatus {
  ACTIVE
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  MERGE
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  displayName String
  role        UserRole @default(MODELER)
  createdAt   DateTime @default(now())

  branchesCreated Branch[]     @relation("BranchCreatedBy")
  auditEvents     AuditEvent[]
}

model Branch {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  status       BranchStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  forkedAt     DateTime     @default(now())
  baseBranchId String?      @db.Uuid
  baseBranch   Branch?      @relation("BranchBase", fields: [baseBranchId], references: [id])
  children     Branch[]     @relation("BranchBase")

  createdById String @db.Uuid
  createdBy   User   @relation("BranchCreatedBy", fields: [createdById], references: [id])

  elements    Element[]
  relations   Relation[]
  auditEvents AuditEvent[]

  @@unique([name])
  @@index([baseBranchId])
}

model Element {
  id       String @id @default(uuid()) @db.Uuid
  /// Stable identifier across branches/merges (Git-like "same logical object")
  key      String @default(uuid()) @db.Uuid
  branchId String @db.Uuid
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name      String
  archiType String // e.g. ArchiMate element type (FA-01)
  layer     String // Business | Application | Information | Technology (FA-01)

  documentation String?
  attributes    Json    @default("{}")

  x Float @default(0)
  y Float @default(0)

  startDate DateTime?
  endOfLife DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, key])
  @@index([branchId])
  @@index([key])
  @@index([layer])
  @@index([archiType])
}

model Relation {
  id       String @id @default(uuid()) @db.Uuid
  key      String @default(uuid()) @db.Uuid
  branchId String @db.Uuid
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  type      String // e.g. ArchiMate relationship type (FA-01)
  sourceKey String @db.Uuid
  targetKey String @db.Uuid

  attributes Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, key])
  @@index([branchId])
  @@index([sourceKey])
  @@index([targetKey])
  @@index([type])
}

model AuditEvent {
  id       String @id @default(uuid()) @db.Uuid
  branchId String @db.Uuid
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  actorUserId String @db.Uuid
  actorUser   User   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  action     AuditAction
  entityType String // "element" | "relation" | "branch" | ...
  entityKey  String?     @db.Uuid
  before     Json?
  after      Json?

  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, createdAt])
}
